{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CandidateItem",
  "type": "object",
  "required": [
    "customer_id",
    "candidate_sku",
    "eclass",
    "manufacturer",
    "candidate_price",
    "reference_price"
  ],
  "properties": {
    "customer_id": {"type": "string"},
    "candidate_sku": {"type": "string"},
    "eclass": {"type": "string"},
    "manufacturer": {"type": "string"},
    "candidate_price": {"type": "number", "minimum": 0},
    "reference_price": {"type": "number", "minimum": 0},
    "global_popularity": {"type": "number", "minimum": 0},
    "manufacturer_familiarity": {"type": "number", "minimum": 0, "maximum": 1}
  }
}
