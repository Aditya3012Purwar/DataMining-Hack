{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Transaction",
  "type": "object",
  "required": [
    "customer_id",
    "sku",
    "manufacturer",
    "eclass",
    "price",
    "date"
  ],
  "properties": {
    "customer_id": {"type": "string"},
    "sku": {"type": "string"},
    "manufacturer": {"type": "string"},
    "eclass": {"type": "string"},
    "price": {"type": "number", "minimum": 0},
    "quantity": {"type": "number", "minimum": 0},
    "date": {"type": "string", "format": "date"}
  }
}
